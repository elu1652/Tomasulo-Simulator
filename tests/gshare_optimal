# gshare_optimal.asm
#
# Test: correlated branches designed to favor GShare
#
# There are two branch sites per loop iteration:
#
#   Branch A: BNE R1, R0, branch_a_taken
#   Branch B: BNE R1, R0, branch_b_taken
#
# R1 toggles between 1 and 0 every iteration.
#
# So each static branch alternates:
#   T N T N T N ...
#
# Local 1-bit and 2-bit predictors tend to struggle with alternating branches.
# GShare can use global history to learn the correlation between recent branch
# outcomes and the current branch outcome.
#
# Final architectural state should be correct for all predictors.
#
# Expected final state:
# R1 = 1
# R2 = 0
# R5 = 1
# R6 = 12
# R9 = 6
# R10 = 6
# R11 = 6
# R12 = 6
#
# EXPECT_REG R1 1
# EXPECT_REG R2 0
# EXPECT_REG R5 1
# EXPECT_REG R6 12
# EXPECT_REG R9 6
# EXPECT_REG R10 6
# EXPECT_REG R11 6
# EXPECT_REG R12 6
# EXPECT_COMMIT_COUNT BNE R1, R0, branch_a_taken 12
# EXPECT_COMMIT_COUNT BNE R1, R0, branch_b_taken 12
# EXPECT_COMMIT_COUNT ADDI R9, R9, 1 6
# EXPECT_COMMIT_COUNT ADDI R10, R10, 1 6
# EXPECT_COMMIT_COUNT ADDI R11, R11, 1 6
# EXPECT_COMMIT_COUNT ADDI R12, R12, 1 6

ADDI R1, R0, 1
ADDI R2, R0, 12
ADDI R5, R0, 1
ADDI R6, R0, 12

ADDI R9, R0, 0
ADDI R10, R0, 0
ADDI R11, R0, 0
ADDI R12, R0, 0

loop:
BNE R1, R0, branch_a_taken

branch_a_not_taken:
ADDI R10, R10, 1
BEQ R0, R0, after_branch_a

branch_a_taken:
ADDI R9, R9, 1

after_branch_a:
BNE R1, R0, branch_b_taken

branch_b_not_taken:
ADDI R12, R12, 1
BEQ R0, R0, after_branch_b

branch_b_taken:
ADDI R11, R11, 1

after_branch_b:
SUB R1, R5, R1
SUB R2, R2, R5
BNE R2, R0, loop